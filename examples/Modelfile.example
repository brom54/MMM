# Example Modelfile for MMM
# Drop this in the modelfiles/ directory and MMM will auto-convert it.
# Or use it with Ollama directly: ollama create my-agent -f Modelfile.example

FROM qwen3:32b

PARAMETER temperature 0.7
PARAMETER top_p 0.85
PARAMETER top_k 20
PARAMETER repeat_penalty 1.1
PARAMETER num_ctx 65536
PARAMETER num_predict 2048

SYSTEM """
You are a helpful AI assistant. Be direct, accurate, and concise.
When you don't know something, say so.
When given a task, complete it fully before responding.
"""
