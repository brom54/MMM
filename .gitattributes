# MMM — Git line ending normalization
# Enforces LF in the repo; handles Windows dev / Linux prod split

* text=auto

# Source and config — always LF
*.py        text eol=lf
*.sh        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.nix       text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.env       text eol=lf
.env*       text eol=lf
*.plist     text eol=lf
*.service   text eol=lf
*.xml       text eol=lf
Modelfile*  text eol=lf

# Windows scripts — CRLF on checkout
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Binary — no line ending processing
*.db        binary
*.pyc       binary
*.png       binary
*.jpg       binary
*.ico       binary
