# MMM — Make Modelfiles Matter
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and edit the values.
# MMM loads .env automatically on startup.
#
# SECURITY: Never commit .env to version control.
# It is already in .gitignore.
# ═══════════════════════════════════════════════════════════════════


# ── Proxy Settings ─────────────────────────────────────────────────

# Port MMM listens on
# Your front-ends (Open WebUI, OpenClaw, etc.) connect to this port
PROXY_PORT=11435

# Where your inference backend is running
# If you moved Ollama to a different port to make room for MMM:
OLLAMA_HOST=http://localhost:11434

# Which backend to use
# Options: ollama, llamacpp, lmstudio, vllm, kobold, mlx
BACKEND=ollama

# Path to your characters config file
# CONFIG_FILE=./characters.json

# Heartbeat interval in seconds
# MMM sends keepalive pings while waiting for inference to start
# Prevents front-end timeouts on slow/large models
HEARTBEAT_INTERVAL=3

# Modelfile ingest directory
# Drop Modelfiles here and MMM will auto-convert and reload characters
# MODELFILES_DIR=./modelfiles

# How often to check for new Modelfiles (seconds)
WATCH_INTERVAL=5


# ── Model Cache ────────────────────────────────────────────────────

# How often to auto-refresh the model list (hours)
# MMM checks this list before inference to catch missing models early
# Set to 0 to disable auto-refresh (manual refresh via POST /mmm/refresh)
MODEL_REFRESH_HOURS=6


# ── Security — Inbound Auth ────────────────────────────────────────
# Controls who can talk TO MMM.
#
# RECOMMENDATION: Always change MMM_API_KEY from the default.
# Store this key in your OS keychain or password manager.
# See README for instructions on using a secrets manager.

# Static API key — required in Authorization: Bearer <key> header
# or X-API-Key: <key> header from all clients connecting to MMM.
#
# Default 'CHANGE_ME' provides basic protection but logs a warning.
# Set to empty string to disable key auth entirely (not recommended).
MMM_API_KEY=CHANGE_ME

# IP allowlist — optional extra layer of security
# Comma-separated IPs or CIDR ranges. Leave empty to allow all IPs.
# Example: MMM_ALLOWED_IPS=192.168.1.0/24,10.0.0.5
MMM_ALLOWED_IPS=


# ── Cloud Provider API Keys — Outbound Auth ────────────────────────
# Keys MMM uses when forwarding requests TO cloud providers.
# Phase 2.5 feature — leave blank if only using local backends.
#
# SECURITY RECOMMENDATION:
# Rather than storing keys here, use your OS keychain:
#   macOS:   security add-generic-password -a mmm -s openai -w sk-...
#   Linux:   secret-tool store --label="MMM OpenAI" service mmm account openai
#   Windows: cmdkey /add:mmm-openai /user:mmm /pass:sk-...
# MMM will detect and use keychain storage automatically in Phase 2.5.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk-...
# MISTRAL_API_KEY=...
# COHERE_API_KEY=...
